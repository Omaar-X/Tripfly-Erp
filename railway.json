{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci --cache /tmp/.npm && npm run build"
  },
  "deploy": {
    "startCommand": "node scripts/railway-service.mjs start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
